[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = OneHalfDark
	hyperlinks = true

[merge]
	tool = nvimdiff3
	conflictstyle = zdiff3

[mergetool]
	keepBackup = false
	prompt = false

[diff]
	tool = nvimdiff
	colorMoved = default

[difftool]
	prompt = false
